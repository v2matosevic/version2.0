# ============================================================
# Version2.hr — Docker Compose Environment Variables
# Copy to .env and fill in production values
# ============================================================

# ── MySQL (shared instance) ──
MYSQL_ROOT_PASSWORD=change-me-strong-root-password

# Per-app DB passwords (used in mysql/init/01-create-databases.sql)
APP_DB_PASSWORD=change-me-app-password
WEB_DB_PASSWORD=change-me-web-password
OFFER_DB_PASSWORD=change-me-offer-password
