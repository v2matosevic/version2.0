# ============================================================
# version2.hr — Next.js Production Environment
# Copy to nextjs.env and fill in production values
# ============================================================

# ── Site ──
NEXT_PUBLIC_SITE_URL=https://version2.hr

# ── Coming Soon Mode ──
COMING_SOON=true

# ── Database ──
DATABASE_PATH=/app/data/version2.db

# ── Email (Zoho SMTP) ──
SMTP_HOST=smtp.zoho.eu
SMTP_PORT=465
SMTP_USER=office@version2.hr
SMTP_PASS=
SMTP_FROM=Version2 <office@version2.hr>

# ── Admin Auth ──
ADMIN_API_KEY=

# ── AI Chat ──
LLM_PROVIDER=anthropic
LLM_API_KEY=
LLM_MODEL=claude-sonnet-4-20250514

# ── Analytics (client-side) ──
NEXT_PUBLIC_GA4_ID=
NEXT_PUBLIC_GOOGLE_ADS_ID=
NEXT_PUBLIC_FB_PIXEL_ID=

# ── Sentry ──
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=
SENTRY_ORG=version2
SENTRY_PROJECT=version2-hr
