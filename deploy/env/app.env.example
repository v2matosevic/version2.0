# ============================================================
# app.version2.hr — Laravel Environment
# Copy to app.env and fill in production values
# ============================================================

APP_NAME="Version2 Cards"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://app.version2.hr
APP_KEY=

DB_CONNECTION=mysql
DB_HOST=v2-mysql
DB_PORT=3306
DB_DATABASE=app_v2cards
DB_USERNAME=v2app
DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=database

MAIL_MAILER=smtp
MAIL_HOST=smtp.zoho.eu
MAIL_PORT=465
MAIL_USERNAME=office@version2.hr
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=office@version2.hr
MAIL_FROM_NAME="Version2 Cards"
