# ============================================================
# web.version2.hr — Laravel Environment
# Copy to web.env and fill in production values
# ============================================================

APP_NAME="Version2 Web"
APP_ENV=production
APP_DEBUG=false
APP_URL=https://web.version2.hr
APP_KEY=

DB_CONNECTION=mysql
DB_HOST=v2-mysql
DB_PORT=3306
DB_DATABASE=web_v2
DB_USERNAME=v2web
DB_PASSWORD=

CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_CONNECTION=sync

MAIL_MAILER=smtp
MAIL_HOST=smtp.zoho.eu
MAIL_PORT=465
MAIL_USERNAME=office@version2.hr
MAIL_PASSWORD=
MAIL_ENCRYPTION=ssl
MAIL_FROM_ADDRESS=office@version2.hr
MAIL_FROM_NAME="Version2 Web"
