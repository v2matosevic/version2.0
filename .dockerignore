# Dependencies
node_modules

# Build output (rebuilt in container)
.next

# Data (mounted as volume)
data/*.db
data/*.db-wal
data/*.db-shm

# Git
.git
.gitignore

# IDE / Editor
.vscode
.idea
*.swp

# Screenshots & dev artifacts
*.png
*.jpg

# Deployment configs (not needed in app image, except nginx which builds its own image)
deploy/env/
deploy/mysql/
deploy/scripts/
deploy/docker-compose.yml

# Environment files (injected at runtime)
.env
.env.local
.env.production

# Claude / AI
.claude/
.mcp.json

# Docs & tasks (not needed at runtime)
docs/
tasks/

# Scripts (keep — needed for postbuild: sitemap, robots, search index)
# scripts/

# OS files
Thumbs.db
.DS_Store
